{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",

  "configurations": [
    {
      "name": "SingleUvicorn/FastApiKeycloak${fileBasename}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "justMyCode": true,
      "args": [
        "src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ]
    },
    {
      "name": "MultiUvicorn/FastApiKeycloak${fileBasename}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "justMyCode": true,
      "args": [
        "src.main:app",
        // "--reload",
        "--workers",
        "4",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ]
    }
  ]
}
