{
  "version": "0.2.0",

  "configurations": [
    {
      "name": "SingleUvicorn/FastApiWeather${fileBasename}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "justMyCode": true,
      "args": [
        "src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ]
    },
    {
      "name": "MultiUvicorn/FastApiWeather${fileBasename}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "justMyCode": true,
      "args": [
        "src.main:app",
        // "--reload",
        "--workers",
        "4",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ]
    }
  ]
}
